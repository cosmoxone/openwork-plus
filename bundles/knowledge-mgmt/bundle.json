{
  "schemaVersion": "1.0.0",
  "contractId": "com.openwork.convergence.bundle",
  "id": "knowledge-mgmt",
  "name": "个人知识库（LLM Wiki）",
  "version": "0.3.0",
  "description": "本机文档梳理 + LLM Wiki + lint + 混合检索 + 向量索引联动",
  "requires": { "runtime": ["opencode"] },
  "preinstall": "node ./scripts/init-knowledge-dirs.mjs",
  "skills": [
    { "path": "skills/wiki-curator" },
    { "path": "skills/corpus-scan" },
    { "path": "skills/summarize-docs" },
    { "path": "skills/find-connections" },
    { "path": "skills/semantic-search" }
  ],
  "commands": [
    { "path": "commands/corpus-scan.md" },
    { "path": "commands/ingest-sources.md" },
    { "path": "commands/knowledge-lint.md" },
    { "path": "commands/summarize-docs.md" },
    { "path": "commands/find-connections.md" },
    { "path": "commands/semantic-search.md" }
  ],
  "mcp": {
    "servers": {
      "sqlite-vec-rag": {
        "command": "node",
        "args": ["${MONOREPO_ROOT}/packages/sqlite-vec-mcp/bin/sqlite-vec-mcp.mjs", "--db", "${WORKSPACE}/knowledge.db"],
        "env": {}
      },
      "filesystem": {
        "command": "npx",
        "args": ["-y", "@modelcontextprotocol/server-filesystem", "${WORKSPACE}"]
      }
    }
  },
  "ui": {
    "routes": ["/docs"]
  }
}
